# Model-service credentials (LLM + ASR API key / base URL / model name) are NO
# LONGER read from env. Enter them once in the app's global Settings screen; they
# are stored in data/model_service.json and shared by every project.
#
# This file only carries operational + storage settings.

DATA_DIR=./data
DB_PATH=./data/mmm.db
REFERENCE_DIR=../reference

# LLM operational knobs (not credentials)
LLM_TIMEOUT=120
LLM_MAX_RETRIES=3

# ASR operational knobs (not credentials)
ASR_TIMEOUT=600
